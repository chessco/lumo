# cp .env.example .env

# ====================
# PITAYACORE INTEGRATION
# ====================
PITAYACORE_AUTH_URL="https://pitayacore-api.pitayacode.io/auth"
PITAYACORE_AI_URL="https://pitayacore-api.pitayacode.io/ai"
PITAYACORE_AGENTS_URL="https://pitayacore-api.pitayacode.io/agents"
PITAYACORE_MEMORY_URL="https://pitayacore-api.pitayacode.io/memory"
PITAYACORE_MEDIA_URL="https://pitayacore-api.pitayacode.io/media"
PITAYACORE_NOTIFICATIONS_URL="https://pitayacore-api.pitayacode.io/notifications"
PITAYACORE_KNOWLEDGE_URL="https://pitayacore-api.pitayacode.io/knowledge"
PITAYACORE_FILES_URL="https://pitayacore-api.pitayacode.io/files"
PITAYACORE_AUDIT_URL="https://pitayacore-api.pitayacode.io/audit"

# ====================
# INTERNAL API KEY
# ====================
INTERNAL_API_KEY="your-internal-api-key-here"
