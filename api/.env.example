# Transactional DB (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/lumo"

# AI
GEMINI_API_KEY="your-gemini-api-key"
JWT_SECRET="your-jwt-secret"

# PitayaCore Integration
PITAYACORE_URL="https://pitayacore-api.pitayacode.io"
INTERNAL_API_KEY="your-internal-api-key"

# Application
PORT=3017
FRONTEND_URL="http://localhost:3000"
NODE_ENV=development

# ============================================
# SPEECH PROVIDERS CONFIGURATION
# ============================================

# Google Cloud Speech
GOOGLE_SPEECH_API_KEY=""
GOOGLE_PROJECT_ID=""

# Azure Cognitive Services Speech
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastus"

# OpenAI (Whisper + TTS)
OPENAI_API_KEY=""

# Provider Selection (optional - defaults shown)
SPEECH_TRANSCRIPTION_PROVIDER="google"
SPEECH_PRONUNCIATION_PROVIDER="google"
SPEECH_FLUENCY_PROVIDER="google"
SPEECH_PHONEMES_PROVIDER="google"
SPEECH_SYNTHESIS_PROVIDER="google"

# ============================================
# SMTP
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Mail Provider (resend | gmail)
MAIL_PROVIDER="gmail"
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="your-email@domain.com"

# ============================================
# Cloudflare R2
# ============================================
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="lumo"
R2_PUBLIC_URL="https://your-r2-public-url.dev"

# Database variables for docker-compose
MYSQL_ROOT_PASSWORD="your-mysql-password"
MYSQL_DATABASE="lumo"
